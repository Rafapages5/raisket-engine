# =====================================================================
# Raisket Engine - Variables de Entorno (Plantilla)
# =====================================================================
# ADVERTENCIA: NUNCA quemes secretos en este archivo ni compartas el original. 
# Copia este archivo como '.env' e introduce tus valores reales.

# -----------------
# Base de Datos (Supabase)
# -----------------
# URL y Auth Key obtenidas desde el panel de Supabase
SUPABASE_URL="https://tu_proyecto.supabase.co"
SUPABASE_KEY="tu_anon_key_o_service_role_key"

# -----------------
# Autenticación y N8N
# -----------------
# Datos para proteger el panel web de n8n
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER="admin_raisket"
N8N_BASIC_AUTH_PASSWORD="cambiame_por_favor"

# Postgres (Base de datos local de control para n8n)
POSTGRES_USER="n8n_user"
POSTGRES_PASSWORD="n8n_password"
POSTGRES_DB="n8n_database"

# -----------------
# Google Cloud Platform (GCP & Vertex AI)
# -----------------
# GCP_PROJECT_ID="raisket-fintech-12345"
# GCP_REGION="us-central1"
# GOOGLE_APPLICATION_CREDENTIALS="/ruta/a/tu/archivo-de-servicio-gcp.json"

# -----------------
# APIs Externas
# -----------------
# Cualquier llave de APIs externas que consuman tus Cloud Functions
# ALPHAVANTAGE_API_KEY=""
# BANXICO_BIE_TOKEN=""
